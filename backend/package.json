{
  "name": "bunker-backend",
  "version": "1.0.0",
  "description": "Backend server for Bunker social deduction game",
  "main": "dist/server.js",
  "scripts": {
    "dev": "BUNKER_CONFIG=../config.toml tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "async-mutex": "^0.5.0",
    "casdoor-nodejs-sdk": "^1.34.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jose": "^6.2.2",
    "lru-cache": "^11.3.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
