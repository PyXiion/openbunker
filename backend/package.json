{
  "name": "bunker-backend",
  "version": "1.0.0",
  "description": "Backend server for Bunker social deduction game",
  "main": "dist/server.js",
  "scripts": {
    "dev": "BUNKER_CONFIG=../config.toml tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "casdoor-nodejs-sdk": "^1.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jose": "^5.1.3",
    "lru-cache": "^11.3.3",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/node-fetch": "^2.6.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  }
}
