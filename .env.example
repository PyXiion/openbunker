# ============================================
# Application Configuration
# ============================================

# Environment (development or production)
NODE_ENV=development

# ============================================
# Domain Configuration
# ============================================

# Backend Domain (e.g., https://bunker.pyxiion.ru)
BACKEND_DOMAIN=http://localhost:3001

# Frontend Domain (e.g., https://bunker.pyxiion.ru)
FRONTEND_DOMAIN=http://localhost:3000

# Casdoor Domain (e.g., https://bunker.pyxiion.ru/casdoor)
CASDOOR_DOMAIN=http://localhost:8000

# ============================================
# Backend Configuration
# ============================================

# Backend Port
BACKEND_PORT=3001

# API Prefix (e.g., /api)
API_PREFIX=/api

# WebSocket Path (relative path, e.g., /socket.io/)
WS_PATH=/socket.io/

# ============================================
# Casdoor Configuration
# ============================================

# Casdoor URL (full URL including protocol, no trailing slash)
CASDOOR_URL=http://localhost:8000

# Casdoor Endpoint (for backend SDK)
