# Backend Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
WS_PATH=/socket.io/

# Zitadel Configuration
ZITADEL_URL=http://localhost:8080
ZITADEL_CLIENT_ID=bunker-frontend
ZITADEL_CLIENT_SECRET=your-client-secret-here
ZITADEL_PROJECT_ID=your-project-id

# Zitadel Service Account (for shadow user creation)
ZITADEL_SERVICE_USER_ID=your-service-user-id
ZITADEL_SERVICE_KEY_ID=your-service-key-id
ZITADEL_SERVICE_KEY=your-service-key

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bunker
